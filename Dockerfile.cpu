FROM adaptfm/adaptfm-base:latest

# Upgrade pip so it can handle gptqmodel 7.x pyproject.toml, then install
COPY gptqmodel-7.0.0.tgz /tmp/gptqmodel.tgz
RUN pip install --upgrade pip && pip install /tmp/gptqmodel.tgz

ENV TRANSFORMERS_OFFLINE=1
ENV HF_DATASETS_OFFLINE=1
ENV HF_HUB_OFFLINE=1

COPY serve_cpu.py /opt/program/serve_default.py

# Model is volume-mounted at runtime: -v /path/to/qwen-weights-gptq:/opt/ml/model
EXPOSE 8080
