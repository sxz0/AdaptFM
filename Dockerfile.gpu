FROM exl3-base:latest
# ^ This image has: adaptfm-base + flash_attn 2.7.4.post1 + ExLlamaV3 v0.0.37 + pydantic<2
# Build it first with: docker commit quantize-ex3 exl3-base:latest

# ── Offline mode ───────────────────────────────────────────────────────────────
# Note: causal-conv1d / flash-linear-attention removed — Qwen3.5-4B is a pure
# transformer (no SSM/linear-attention layers), so these packages are not needed.
ENV TRANSFORMERS_OFFLINE=1
ENV HF_DATASETS_OFFLINE=1
ENV HF_HUB_OFFLINE=1

# ── Bake in EXL3 quantised weights (4bpw) ─────────────────────────────────────
# Weights first — they're large and rarely change, so putting them before the
# serve script means editing serve_gpu.py doesn't bust the weights cache layer.
# Weights are supplied via BuildKit named context "weights" to avoid copying
# 4 GB into the build workspace (which may be on a small disk).
#
# Build command (see submit.sh):
#   DOCKER_BUILDKIT=1 docker build \
#     --build-context weights=/data/models/qwen-weights-exl3-4bpw \
#     -f Dockerfile.gpu -t afm-submission:latest .
COPY --from=weights . /opt/ml/model/

# ── Serve script & no-think jinja template ────────────────────────────────────
COPY serve_gpu.py /opt/program/serve_default.py
COPY qwen_no_think.jinja /opt/ml/qwen_no_think.jinja

EXPOSE 8080

ENTRYPOINT ["python3", "/opt/program/serve_default.py"]
